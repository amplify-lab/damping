# Go build artifacts
/cli/damping
/cli/damping.exe
*.test
*.out

# GoReleaser output (dist/) — see .goreleaser.yaml; `goreleaser release
# --snapshot --clean --skip=publish` regenerates this locally on demand
/dist/

# Editor/OS cruft
.DS_Store
*.swp
.idea/
.vscode/

# Secret/credential files — this project's whole purpose is guarding against
# exactly this class of accidental exposure, so its own repo should too
.env
.env.*
!.env.example
*.pem
*.key
credentials.json
id_rsa*
id_ed25519*
.aws/
.ssh/

# Local damping state if ever created inside the repo during manual testing
/.damping/

# Claude Code session-local state (not project content)
/.claude/
